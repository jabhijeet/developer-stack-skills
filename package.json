  "keywords": [
    "ai-agents",
    "skills",
    "claude",
    "cline",
    "roocode",
    "copilot",
    "cursor",
    "java",
    "spring-boot",
    "python",
    "fastapi",
    "react",
    "angular",
    "typescript",
    "testing",
    "conventions"
  ],
  "author": "Abhijeet",
  "repository": {
    "type": "git",
    "url": "https://github.com/jabhijeet/developer-stack-skills.git"
  },
  "license": "MIT",
  "bin": {
    "developer-stack-skills": "bin/developer-stack-skills.js"
  },
  "engines": {
